{
  "name": "sentiment-dash",
  "version": "1.0.0",
  "private": true,
  "description": "Market Sentiment Dashboard with AI-powered insights",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "node scripts/e2e-agent.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "docker:build": "docker build -t sentiment-dash:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "scrape": "ts-node scripts/manual-scrape.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
